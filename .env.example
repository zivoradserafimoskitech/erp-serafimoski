# ===== ERP Серафимоски Тек - Environment Variables =====

# Database (MySQL)
DATABASE_URL=mysql://user:password@localhost:3306/serafimoski

# JWT Secret (generate: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-here

# Certificate Encryption Key (generate: openssl rand -hex 32)
CERT_ENCRYPTION_KEY=your-cert-encryption-key

# Frontend API URL (for production build)
# VITE_API_URL=https://erp.vashdomain.mk/api/trpc

# Email IMAP (optional - for receiving invoices)
# EMAIL_IMAP_HOST=mail.vashdomain.mk
# EMAIL_IMAP_PORT=993
# EMAIL_IMAP_SECURE=true
# EMAIL_USER=erp@vashdomain.mk
# EMAIL_PASS=your-email-password

# UJP e-Faktura (test mode by default)
# UJP_ENV=test
# UJP_API_KEY=your-ujp-api-key
